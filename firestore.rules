rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Products: public read, admin or functions write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      // Prices subcollection: same rules as parent
      match /prices/{priceId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Retailer products: public read, admin or functions write
    match /retailerProducts/{retailerProductId} {
      allow read: if true;
      allow write: if isAdmin();

      // Prices subcollection: same rules as parent
      match /prices/{priceId} {
        allow read: if true;
        allow write: if isAdmin();
      }
    }

    // Users: read/write own document only
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Price alerts: read/write own documents only
    match /priceAlerts/{alertId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
  }
}
